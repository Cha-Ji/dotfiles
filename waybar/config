{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 8,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "network", "pulseaudio", "tray"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true
    },

    "clock": {
        "format": "{:%m/%d (%a) %H:%M}",
        "tooltip-format": "{:%Y-%m-%d %A}"
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 3
    },

    "memory": {
        "format": " {percentage}%",
        "interval": 5
    },

    "network": {
        "format-wifi": "  {signalStrength}%",
        "format-ethernet": " {ifname}",
        "format-disconnected": " 없음",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " mute",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "tray": {
        "spacing": 8
    }
}
